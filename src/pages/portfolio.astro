---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import placeholder1 from '../assets/Genes.png';
import placeholder2 from '../assets/Artwork-30.png';
import placeholder3 from '../assets/MHS_Cybercrime_Poster.png';
import placeholder4 from '../assets/blog-placeholder-4.jpg';
import placeholder5 from '../assets/blog-placeholder-5.jpg';
import placeholderAbout from '../assets/blog-placeholder-about.jpg';

const pieces = [
  { src: placeholder1, title: 'Gene Editing', medium: 'Digital' },
  { src: placeholder2, title: 'Generic Artwork #30', medium: 'Digital' },
  { src: placeholder3, title: 'Milpitas High Cybercrime Poster Challenge', medium: 'Digital' },
  { src: placeholder4, title: 'Untitled 4', medium: 'Pencil on paper' },
  { src: placeholder5, title: 'Untitled 5', medium: 'Digital' },
  { src: placeholderAbout, title: 'Untitled 6', medium: 'Ink on paper' },
];
---

<BaseLayout title="Portfolio | Nandika Trivedi">
  <h1>Portfolio</h1>
  <p class="intro">A collection of digital and traditional artwork.</p>

  <div class="masonry">
    {pieces.map(piece => (
      <figure class="piece">
        <button class="lightbox-trigger" data-title={piece.title} data-medium={piece.medium}>
          <Image src={piece.src} alt={piece.title} widths={[400, 700]} sizes="(max-width: 600px) 100vw, (max-width: 900px) 50vw, 33vw" />
        </button>
        <figcaption>
          <span class="piece-title">{piece.title}</span>
          <span class="piece-medium">{piece.medium}</span>
        </figcaption>
      </figure>
    ))}
  </div>

  <div id="lightbox" role="dialog" aria-modal="true" aria-label="Image viewer">
    <button id="lightbox-close" aria-label="Close">&#x2715;</button>
    <div id="lightbox-content">
      <img id="lightbox-img" src="" alt="" />
      <div id="lightbox-caption">
        <span id="lightbox-title"></span>
        <span id="lightbox-medium"></span>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .intro {
    color: #555;
    margin-bottom: 2rem;
  }

  .masonry {
    columns: 3 220px;
    column-gap: 1.25rem;
  }

  .piece {
    break-inside: avoid;
    margin: 0 0 1.25rem 0;
    background: #f8f8f8;
    border-radius: 8px;
    overflow: hidden;
  }

  .lightbox-trigger {
    display: block;
    width: 100%;
    padding: 0;
    border: none;
    background: none;
    cursor: zoom-in;
  }

  .lightbox-trigger img {
    width: 100%;
    height: auto;
    display: block;
    transition: opacity 0.15s ease;
  }

  .lightbox-trigger:hover img {
    opacity: 0.88;
  }

  figcaption {
    padding: 0.6rem 0.75rem 0.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .piece-title {
    font-weight: 600;
    font-size: 0.9rem;
    color: #111;
  }

  .piece-medium {
    font-size: 0.78rem;
    color: #777;
  }

  /* Lightbox */
  #lightbox {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.92);
    z-index: 1000;
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
  }

  #lightbox.open {
    display: flex;
  }

  #lightbox-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    max-width: 90vw;
    max-height: 90vh;
  }

  #lightbox-img {
    max-width: 90vw;
    max-height: 80vh;
    object-fit: contain;
    border-radius: 4px;
    display: block;
  }

  #lightbox-caption {
    margin-top: 0.75rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  #lightbox-title {
    color: #fff;
    font-weight: 600;
    font-size: 1rem;
  }

  #lightbox-medium {
    color: #aaa;
    font-size: 0.85rem;
  }

  #lightbox-close {
    position: fixed;
    top: 1rem;
    right: 1.25rem;
    background: none;
    border: none;
    color: #fff;
    font-size: 1.75rem;
    cursor: pointer;
    line-height: 1;
    opacity: 0.7;
  }

  #lightbox-close:hover {
    opacity: 1;
  }
</style>

<script>
  const lightbox = document.getElementById('lightbox')!;
  const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;
  const lightboxTitle = document.getElementById('lightbox-title')!;
  const lightboxMedium = document.getElementById('lightbox-medium')!;
  const closeBtn = document.getElementById('lightbox-close')!;

  document.querySelectorAll('.lightbox-trigger').forEach(btn => {
    btn.addEventListener('click', () => {
      const img = btn.querySelector('img')!;
      lightboxImg.src = img.src;
      lightboxImg.alt = img.alt;
      lightboxTitle.textContent = (btn as HTMLElement).dataset.title ?? '';
      lightboxMedium.textContent = (btn as HTMLElement).dataset.medium ?? '';
      lightbox.classList.add('open');
      document.body.style.overflow = 'hidden';
    });
  });

  const close = () => {
    lightbox.classList.remove('open');
    document.body.style.overflow = '';
  };

  closeBtn.addEventListener('click', close);

  lightbox.addEventListener('click', e => {
    if (e.target === lightbox) close();
  });

  document.addEventListener('keydown', e => {
    if (e.key === 'Escape') close();
  });
</script>
