---
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import girlsEducationImg from '../../assets/Girls-Ed.jpg';
import summerResearchImg from '../../assets/blog-placeholder-2.jpg';

const projects = [
  {
    title: 'Girls Education Initiative',
    description: 'A community-driven effort to expand educational opportunities for girls in underserved communities in India.',
    href: '/projects/girls-education',
    image: girlsEducationImg,
    alt: 'Girls Education Initiative',
  },
  {
    title: 'Summer Research: NET & Nitric-Oxide Pathway Gene Expression',
    description: 'A bioinformatic re-analysis of neutrophil extracellular trap and nitric-oxide pathway gene expression in inflammatory disease.',
    href: '/projects/summer-research',
    image: summerResearchImg,
    alt: 'Summer Research',
  },
];
---

<BaseLayout title="Projects | Nandika Trivedi">
  <h1>Projects</h1>

  <ul class="project-list">
    {projects.map(project => (
      <li class="project-card">
        <a href={project.href} class="project-image-link">
          <Image src={project.image} alt={project.alt} width={280} height={180} />
        </a>
        <div class="project-info">
          <h2><a href={project.href}>{project.title}</a></h2>
          <p>{project.description}</p>
        </div>
      </li>
    ))}
  </ul>
</BaseLayout>

<style>
  .project-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .project-card {
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
  }

  .project-image-link {
    flex-shrink: 0;
  }

  .project-image-link img {
    width: 280px;
    height: 180px;
    object-fit: cover;
    border-radius: 8px;
    display: block;
  }

  .project-info {
    flex: 1;
  }

  .project-info h2 {
    font-size: 1.2rem;
    margin: 0 0 0.5rem 0;
  }

  .project-info h2 a {
    text-decoration: none;
    color: inherit;
  }

  .project-info h2 a:hover {
    text-decoration: underline;
  }

  .project-info p {
    margin: 0;
    color: #555;
    font-size: 0.95rem;
    line-height: 1.5;
  }

  @media (max-width: 600px) {
    .project-card {
      flex-direction: column;
    }

    .project-image-link img {
      width: 100%;
      height: auto;
    }
  }
</style>
