---
const { title = "Nandika Trivedi" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>

    <style>
      body {
        font-family: system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
        margin: 0;
        line-height: 1.6;
        color: #111;
        background: #fff;
      }

      header {
        border-bottom: 1px solid #eee;
        padding: 16px 24px;
      }

      nav {
        display: flex;
        gap: 16px;
        flex-wrap: wrap;
      }

      nav a {
        text-decoration: none;
        color: #333;
      }

      nav a:hover {
        text-decoration: underline;
      }

      main {
        max-width: 800px;
        margin: 40px auto;
        padding: 0 20px;
      }

      footer {
        border-top: 1px solid #eee;
        margin-top: 60px;
        padding: 20px;
        text-align: center;
        font-size: 14px;
        color: #666;
      }

      h1, h2, h3 {
        line-height: 1.2;
      }

      .container {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }

      main {
        flex: 1;
      }
    </style>
  </head>

  <body>
    <div class="container">
      <header>
        <nav>
          <a href="/">Home</a>
          <a href="/about">About</a>
          <a href="/projects">Projects</a>
          <a href="/portfolio">Portfolio</a>
          <a href="/impact">Impact</a>
          <a href="/blog">Blog</a>
          <a href="/resume">Resume</a>
          <a href="/contact">Contact</a>
        </nav>
      </header>

      <main>
        <slot />
      </main>

      <footer>
        © {new Date().getFullYear()} Nandika Trivedi
      </footer>
    </div>
  </body>
</html>
